NODE_ENV=production
PORT=5000
API_PREFIX=/api
APP_NAME=SAIP_API

DATABASE_URL=postgresql://postgres:password@localhost:5432/saip_db?schema=public
EMPLOYEE_DIRECTORY_DATABASE_URL=

REDIS_URL=redis://localhost:6379
DISABLE_QUEUES=false

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=https://<your-frontend-service>.onrender.com

COOKIE_DOMAIN=
COOKIE_SECURE=true

AI_SERVICE_URL=
AI_SERVICE_API_KEY=
AI_SERVICE_TIMEOUT_MS=10000
GOOGLE_VISION_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_TRANSLATE_BASE_URL=https://translation.googleapis.com/language/translate/v2
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1/places:searchNearby
GOOGLE_PLACES_RADIUS_METERS=5000
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

SMS_PROVIDER=mock
SMS_API_KEY=

STORAGE_DRIVER=local
STORAGE_BUCKET=saip-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

MAX_FILE_SIZE_MB=10
UPLOAD_TEMP_DIR=uploads/tmp

QUEUE_PREFIX=saip
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
