    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
