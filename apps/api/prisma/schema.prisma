generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CITIZEN
  EMPLOYEE
  DEPARTMENT_ADMIN
  SUPER_ADMIN
}

enum ComplaintStatus {
  SUBMITTED
  UNDER_REVIEW
  ASSIGNED
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
  REOPENED
  CLOSED
}

enum EvidenceType {
  BEFORE
  AFTER
  INVOICE
  OTHER
}

enum NotificationType {
  SYSTEM
  COMPLAINT_STATUS
  ASSIGNMENT
  EVIDENCE
  RESOLVED
  VERIFIED
  TICKET
  CHAT_MESSAGE
}

enum TicketStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChatbotMessageRole {
  USER
  ASSISTANT
}

enum ChatbotResponseSource {
  KNOWLEDGE_BASE
  AI
  FALLBACK
}

enum DailyBoostType {
  JOKE
  THOUGHT
  TIP
  QUOTE
}

enum DailyBoostMood {
  HAPPY
  STRESS
  ANGRY
}

model Department {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  users       User[]
  complaints  Complaint[]
  assignments ComplaintAssignment[]
  feedbacks   ComplaintFeedback[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model User {
  id                String                @id @default(uuid())
  fullName          String
  email             String                @unique
  phone             String?               @unique
  passwordHash      String                @map("password")
  role              UserRole              @default(CITIZEN)
  isActive          Boolean               @default(true)
  departmentId      String?
  department        Department?           @relation(fields: [departmentId], references: [id])
  complaints        Complaint[]           @relation("CitizenComplaints")
  assignedComplaints Complaint[]          @relation("AssignedComplaints")
  assignments       ComplaintAssignment[] @relation("EmployeeAssignments")
  assignedBy        ComplaintAssignment[] @relation("AssignedByUsers")
  statusChanges     ComplaintStatusLog[]
  evidenceUploads   Evidence[]            @relation("EvidenceUploadedBy")
  reviewedEvidence  Evidence[]            @relation("EvidenceReviewedBy")
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  chatbotMessages   ChatbotMessage[]
  complaintComments ComplaintComment[]
  complaintTimelineEntries ComplaintTimelineEntry[] @relation("TimelineEntryActor")
  citizenFeedbacks  ComplaintFeedback[]   @relation("ComplaintFeedbackCitizen")
  officerFeedbacks  ComplaintFeedback[]   @relation("ComplaintFeedbackOfficer")
  raisedTickets     Ticket[]              @relation("TicketRaisedBy")
  savedContent      SavedContent[]        @relation("UserSavedContent")
  likedContent      UserLike[]            @relation("UserLikedContent")
  showSanitaryFeature Boolean             @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

   @@map("user")  // fix
}

model Complaint {
  id                String               @id @default(uuid())
  title             String
  description       String
  status            ComplaintStatus      @default(OPEN)
  issueType         String?
  urgencyScore      Int?
  tags              String[]             @default([])
  structuredAddress Json?
  category          String?
  priority          String?
  locationAddress   String?
  latitude          Decimal?             @db.Decimal(10, 7)
  longitude         Decimal?             @db.Decimal(10, 7)
  imagePath         String?
  aiCategory        String?
  aiPriority        String?
  aiConfidence      Float?
  duplicateScore    Float?
  fraudScore        Float?
  isSuspicious      Boolean              @default(false)
  fraudSignals      Json?
  duplicateComplaintId String?
  citizenId         String
  citizen           User                 @relation("CitizenComplaints", fields: [citizenId], references: [id])
  departmentId      String?
  department        Department?          @relation(fields: [departmentId], references: [id])
  assignedEmployeeId String?
  assignedEmployee  User?                @relation("AssignedComplaints", fields: [assignedEmployeeId], references: [id])
  reopenedCount     Int                  @default(0)
  lastStatusChangedAt DateTime           @default(now())
  resolvedAt        DateTime?
  closedAt          DateTime?
  rejectedAt        DateTime?
  reopenedAt        DateTime?
  assignments       ComplaintAssignment[]
  statusHistory     ComplaintStatusLog[]
  evidenceItems     Evidence[]
  comments          ComplaintComment[]
  timelineEntries   ComplaintTimelineEntry[]
  feedback          ComplaintFeedback?
  tickets           Ticket[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([citizenId, createdAt])
  @@index([status, createdAt])
  @@index([departmentId, status])
  @@index([assignedEmployeeId, status])
  @@index([isSuspicious, fraudScore])
}

model ComplaintAssignment {
  id            String      @id @default(uuid())
  complaintId   String
  complaint     Complaint   @relation(fields: [complaintId], references: [id])
  employeeId    String
  employee      User        @relation("EmployeeAssignments", fields: [employeeId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  assignedById  String
  assignedBy    User        @relation("AssignedByUsers", fields: [assignedById], references: [id])
  note          String?
  createdAt     DateTime    @default(now())
}

model ComplaintStatusLog {
  id          String          @id @default(uuid())
  complaintId String
  complaint   Complaint       @relation(fields: [complaintId], references: [id])
  status      ComplaintStatus
  note        String?
  changedById String?
  changedBy   User?           @relation(fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())
}

model Evidence {
  id                  String       @id @default(uuid())
  complaintId         String
  complaint           Complaint    @relation(fields: [complaintId], references: [id])
  uploadedById        String
  uploadedBy          User         @relation("EvidenceUploadedBy", fields: [uploadedById], references: [id])
  reviewedById        String?
  reviewedBy          User?        @relation("EvidenceReviewedBy", fields: [reviewedById], references: [id])
  type                EvidenceType
  fileName            String
  filePath            String
  mimeType            String
  fileSize            Int
  note                String?
  ocrText             String?
  ocrConfidence       Float?
  ocrFields           Json?
  verificationStatus  String?      @default("PENDING")
  reviewRemarks       String?
  reviewedAt          DateTime?
  invoiceVendorName   String?
  invoiceNumber       String?
  invoiceDate         DateTime?
  invoiceAmount       Decimal?     @db.Decimal(12, 2)
  latitude            Decimal?     @db.Decimal(10, 7)
  longitude           Decimal?     @db.Decimal(10, 7)
  duplicateScore      Float?
  isDuplicate         Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([complaintId, type])
  @@index([verificationStatus, createdAt])
}

model ComplaintComment {
  id          String    @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  comment     String
  createdAt   DateTime  @default(now())

  @@index([complaintId, createdAt])
}

model ComplaintTimelineEntry {
  id          String    @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  eventType   String
  title       String
  description String?
  metadata    Json?
  createdById String?
  createdBy   User?     @relation("TimelineEntryActor", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([complaintId, createdAt])
}

model ComplaintFeedback {
  id           String      @id @default(uuid())
  complaintId  String      @unique
  complaint    Complaint   @relation(fields: [complaintId], references: [id])
  citizenId    String
  citizen      User        @relation("ComplaintFeedbackCitizen", fields: [citizenId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  officerId    String?
  officer      User?       @relation("ComplaintFeedbackOfficer", fields: [officerId], references: [id])
  rating       Int
  comment      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([departmentId, createdAt])
  @@index([officerId, createdAt])
}

model Ticket {
  id          String       @id @default(uuid())
  complaintId String
  complaint   Complaint    @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  raisedById  String
  raisedBy    User         @relation("TicketRaisedBy", fields: [raisedById], references: [id], onDelete: Cascade)
  message     String
  status      TicketStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@index([complaintId, createdAt])
  @@index([raisedById, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  complaintId String?
  type      NotificationType
  title     String
  message   String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([complaintId])
}

model ChatbotKnowledgeEntry {
  id                 String           @id @default(uuid())
  question           String
  normalizedQuestion String           @unique
  answer             String
  keywords           String[]         @default([])
  category           String?
  isSeed             Boolean          @default(false)
  messages           ChatbotMessage[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([category, createdAt])
}

model ChatbotMessage {
  id               String                 @id @default(uuid())
  userId           String
  user             User                   @relation(fields: [userId], references: [id])
  role             ChatbotMessageRole
  content          String
  responseSource   ChatbotResponseSource?
  knowledgeEntryId String?
  knowledgeEntry   ChatbotKnowledgeEntry? @relation(fields: [knowledgeEntryId], references: [id])
  createdAt        DateTime               @default(now())

  @@index([userId, createdAt])
  @@index([knowledgeEntryId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
}

model AuditLog {
  id         String    @id @default(uuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model DailyBoostContent {
  id         String         @id @default(uuid())
  type       DailyBoostType
  mood       DailyBoostMood
  language   String         @db.VarChar(16)
  pincode    String?
  content    String
  emoji      String?
  prompt     String?
  model      String?
  source     String?
  likesCount Int            @default(0)
  expiresAt  DateTime?
  savedBy    SavedContent[]
  likedBy    UserLike[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([type, mood, language, createdAt])
  @@index([pincode, createdAt])
}

model SavedContent {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation("UserSavedContent", fields: [userId], references: [id])
  contentId String
  content   DailyBoostContent @relation(fields: [contentId], references: [id])
  createdAt DateTime         @default(now())

  @@unique([userId, contentId])
  @@index([userId, createdAt])
  @@map("saved_content")
}

model UserLike {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation("UserLikedContent", fields: [userId], references: [id])
  contentId String
  content   DailyBoostContent @relation(fields: [contentId], references: [id])
  createdAt DateTime         @default(now())

  @@unique([userId, contentId])
  @@index([userId, createdAt])
  @@map("user_likes")
}
