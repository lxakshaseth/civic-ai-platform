{
  "name": "smart-ai-civic-intelligence-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "npm run start:api",
    "build:frontend": "npm run build --workspace frontend",
    "build:api": "npm run build --workspace @saip/api",
    "start:frontend": "npm run start --workspace frontend",
    "start:api": "npm run start --workspace @saip/api",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "dependencies": {
    "ioredis": "^5.10.1"
  }
}
